// ════════════════════════════════════════════════════════════════
// NILAI
// ════════════════════════════════════════════════════════════════
function handleGetNilaiMhs(data) {
  const { userId } = data;
  const nilai = getSheetData(SHEETS.NILAI).find(n => n.mahasiswa_id === userId) || {};
  // Hitung rata2 tugas & kuis otomatis
  const submisi = getSheetData(SHEETS.TUGAS_SUBMIT).filter(s => s.mahasiswa_id === userId && s.nilai !== "");
  const tugasRata = submisi.length ? (submisi.reduce((a, s) => a + Number(s.nilai), 0) / submisi.length).toFixed(1) : "-";
  const kJawaban = getSheetData(SHEETS.KUIS_JAWABAN).filter(k => k.mahasiswa_id === userId && k.status === "dinilai");
  const kuisRata = kJawaban.length ? (kJawaban.reduce((a, k) => a + Number(k.nilai), 0) / kJawaban.length).toFixed(1) : "-";
  // Absensi
  const absensi = getSheetData(SHEETS.ABSENSI).filter(a => a.mahasiswa_id === userId);
  const hadir = absensi.filter(a => a.status === "hadir").length;
  return jsonRes({ ok: true, nilai: { ...nilai, tugas_rata: tugasRata, kuis_rata: kuisRata, hadir, total_absensi: absensi.length } });
}

function handleUpdateNilai(data) {
  const { mahasiswaId, uts, uas, nilaiAkhir } = data;
  const huruf = getNilaiHuruf(Number(nilaiAkhir));
  const existing = getSheetData(SHEETS.NILAI).find(n => n.mahasiswa_id === mahasiswaId);
  if (existing) {
    updateRow(SHEETS.NILAI, "mahasiswa_id", mahasiswaId, { uts, uas, nilai_akhir: nilaiAkhir, huruf, updated_at: now() });
  } else {
    appendRow(SHEETS.NILAI, [mahasiswaId, uts || "", uas || "", "", "", nilaiAkhir, huruf, now()]);
  }
  return jsonRes({ ok: true });
}

function handleGetAllMahasiswa() {
  const mhs = getSheetData(SHEETS.MAHASISWA);
  const nilai = getSheetData(SHEETS.NILAI);
  const absensi = getSheetData(SHEETS.ABSENSI);
  const enriched = mhs.map(m => {
    const n = nilai.find(n => n.mahasiswa_id === m.id) || {};
    const hadir = absensi.filter(a => a.mahasiswa_id === m.id && a.status === "hadir").length;
    return { ...m, password: undefined, nilai_akhir: n.nilai_akhir || "", huruf: n.huruf || "", hadir };
  });
  return jsonRes({ ok: true, mahasiswa: enriched });
}

function handleDeleteMahasiswa(data) {
  deleteRow(SHEETS.MAHASISWA, "id", data.id);
  return jsonRes({ ok: true });
}

function handleUpdateProfile(data) {
  const { userId, nama, nim, prodi, semester } = data;
  updateRow(SHEETS.MAHASISWA, "id", userId, { nama, nim, prodi, semester });
  return jsonRes({ ok: true });
}

// ════════════════════════════════════════════════════════════════
// HELPERS — SPREADSHEET CRUD
// ════════════════════════════════════════════════════════════════
function getSheet(name) {
  return SpreadsheetApp.getActiveSpreadsheet().getSheetByName(name);
}

function getSheetData(name) {
  const sh = getSheet(name);
  if (!sh || sh.getLastRow() < 2) return [];
  const [headers, ...rows] = sh.getDataRange().getValues();
  return rows.map(r => {
    const obj = {};
    headers.forEach((h, i) => { obj[h] = r[i] === undefined || r[i] === null ? "" : String(r[i]); });
    return obj;
  }).filter(r => Object.values(r).some(v => v !== ""));
}

function appendRow(name, vals) {
  getSheet(name).appendRow(vals);
}

function updateRow(name, keyCol, keyVal, updates) {
  const sh = getSheet(name);
  const data = sh.getDataRange().getValues();
  const headers = data[0];
  const keyIdx = headers.indexOf(keyCol);
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][keyIdx]) === String(keyVal)) {
      for (const [col, val] of Object.entries(updates)) {
        const ci = headers.indexOf(col);
        if (ci >= 0) sh.getRange(i + 1, ci + 1).setValue(val);
      }
      return;
    }
  }
}

function deleteRow(name, keyCol, keyVal) {
  const sh = getSheet(name);
  const data = sh.getDataRange().getValues();
  const headers = data[0];
  const keyIdx = headers.indexOf(keyCol);
  for (let i = data.length - 1; i >= 1; i--) {
    if (String(data[i][keyIdx]) === String(keyVal)) { sh.deleteRow(i + 1); return; }
  }
}

function deleteRowsWhere(name, keyCol, keyVal) {
  const sh = getSheet(name);
  const data = sh.getDataRange().getValues();
  const headers = data[0];
  const keyIdx = headers.indexOf(keyCol);
  for (let i = data.length - 1; i >= 1; i--) {
    if (String(data[i][keyIdx]) === String(keyVal)) sh.deleteRow(i + 1);
  }
}

