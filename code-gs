function handleAddSoal(data) {
  const { kuisId, urutan, tipe, pertanyaan, pilihanA, pilihanB, pilihanC, pilihanD, jawabanBenar, bobot } = data;
  if (!pertanyaan) return jsonRes({ ok: false, msg: "Pertanyaan wajib diisi" });
  appendRow(SHEETS.KUIS_SOAL, [uid(), kuisId, urutan, tipe, pertanyaan, pilihanA || "", pilihanB || "", pilihanC || "", pilihanD || "", jawabanBenar || "", bobot || 10]);
  return jsonRes({ ok: true });
}

function handleDeleteSoal(data) {
  deleteRow(SHEETS.KUIS_SOAL, "id", data.id);
  return jsonRes({ ok: true });
}

function handleSubmitKuis(data) {
  const { kuisId, mahasiswaId, jawabanJson } = data;
  const existing = getSheetData(SHEETS.KUIS_JAWABAN).find(j => j.kuis_id === kuisId && j.mahasiswa_id === mahasiswaId);
  if (existing) return jsonRes({ ok: false, msg: "Sudah pernah mengerjakan" });
  const soalList = getSheetData(SHEETS.KUIS_SOAL).filter(s => s.kuis_id === kuisId);
  const jawaban = JSON.parse(jawabanJson);
  let totalNilai = 0, totalBobot = 0, hasEssay = false;
  soalList.forEach(s => {
    totalBobot += Number(s.bobot) || 10;
    if (s.tipe === "pilihan_ganda") {
      const jwb = jawaban[s.id] || "";
      if (jwb.toUpperCase() === (s.jawaban_benar || "").toUpperCase()) totalNilai += Number(s.bobot);
    } else { hasEssay = true; }
  });
  const pgBobot = soalList.filter(s => s.tipe === "pilihan_ganda").reduce((a, s) => a + Number(s.bobot), 0);
  const nilaiPG = pgBobot > 0 ? Math.round((totalNilai / pgBobot) * 100) : 0;
  const status = hasEssay ? "selesai" : "dinilai";
  const nilaiAkhir = hasEssay ? "" : nilaiPG;
  appendRow(SHEETS.KUIS_JAWABAN, [uid(), kuisId, mahasiswaId, jawabanJson, nilaiAkhir, status, now()]);
  return jsonRes({ ok: true, nilai: nilaiAkhir, status });
}

function handleGetHasilKuis(data) {
  const list = getSheetData(SHEETS.KUIS_JAWABAN).filter(j => j.kuis_id === data.kuisId);
  if (data.mahasiswaId) {
    const mine = list.find(j => j.mahasiswa_id === data.mahasiswaId);
    if (!mine) return jsonRes({ ok: true, hasil: null });
    const soal = getSheetData(SHEETS.KUIS_SOAL).filter(s => s.kuis_id === data.kuisId).sort((a, b) => a.urutan - b.urutan);
    return jsonRes({ ok: true, hasil: mine, soal });
  }
  const mhs = getSheetData(SHEETS.MAHASISWA);
  const enriched = list.map(j => {
    const m = mhs.find(m => m.id === j.mahasiswa_id) || {};
    return { ...j, mahasiswa_nama: m.nama || "-", mahasiswa_nim: m.nim || "-" };
  });
  return jsonRes({ ok: true, hasil: enriched });
}

function handleNilaiEssay(data) {
  const { jawabanId, kuisId, mahasiswaId, nilaiEssay } = data;
  const soalList = getSheetData(SHEETS.KUIS_SOAL).filter(s => s.kuis_id === kuisId);
  const jawaban = getSheetData(SHEETS.KUIS_JAWABAN).find(j => j.id === jawabanId);
  if (!jawaban) return jsonRes({ ok: false, msg: "Data tidak ditemukan" });
  const parsed = JSON.parse(jawaban.jawaban_json || "{}");
  const pgSoal = soalList.filter(s => s.tipe === "pilihan_ganda");
  const essaySoal = soalList.filter(s => s.tipe === "essay");
  let pgNilai = 0;
  pgSoal.forEach(s => { if ((parsed[s.id] || "").toUpperCase() === (s.jawaban_benar || "").toUpperCase()) pgNilai += Number(s.bobot); });
  const totalBobot = soalList.reduce((a, s) => a + Number(s.bobot), 0);
  const essayBobot = essaySoal.reduce((a, s) => a + Number(s.bobot), 0);
  const essayNilai = Object.values(nilaiEssay).reduce((a, v) => a + Number(v), 0);
  const finalNilai = totalBobot > 0 ? Math.round(((pgNilai + essayNilai) / totalBobot) * 100) : 0;
  const newJson = JSON.stringify({ ...parsed, _essay_nilai: nilaiEssay });
  updateRow(SHEETS.KUIS_JAWABAN, "id", jawabanId, { jawaban_json: newJson, nilai: finalNilai, status: "dinilai" });
  return jsonRes({ ok: true, nilai: finalNilai });
}

// ════════════════════════════════════════════════════════════════
// ABSENSI
// ════════════════════════════════════════════════════════════════
function handleGetAbsensi(data) {
  const { prtId, userId, role } = data;
  if (role === "dosen") {
    const absensi = getSheetData(SHEETS.ABSENSI).filter(a => a.pertemuan_id === prtId);
    const mhs = getSheetData(SHEETS.MAHASISWA);
    const enriched = absensi.map(a => {
      const m = mhs.find(m => m.id === a.mahasiswa_id) || {};
      return { ...a, mahasiswa_nama: m.nama || "-", mahasiswa_nim: m.nim || "-" };
    });
    const terdaftar = mhs.map(m => {
      const abs = absensi.find(a => a.mahasiswa_id === m.id);
      return { mahasiswa_id: m.id, mahasiswa_nama: m.nama, mahasiswa_nim: m.nim, status: abs?.status || "belum", keterangan: abs?.keterangan || "", absensi_id: abs?.id || null };
    });
    return jsonRes({ ok: true, absensi: terdaftar });
  } else {
    const absensi = getSheetData(SHEETS.ABSENSI).filter(a => a.mahasiswa_id === userId);
    return jsonRes({ ok: true, absensi });
  }
}

function handleSubmitAbsensi(data) {
  const { prtId, mahasiswaId, status, keterangan } = data;
  const existing = getSheetData(SHEETS.ABSENSI).find(a => a.pertemuan_id === prtId && a.mahasiswa_id === mahasiswaId);
  if (existing) return jsonRes({ ok: false, msg: "Absensi sudah dicatat" });
  appendRow(SHEETS.ABSENSI, [uid(), prtId, mahasiswaId, status || "hadir", keterangan || "", now()]);
  return jsonRes({ ok: true });
}

function handleUpdateAbsensi(data) {
  const { prtId, mahasiswaId, status, keterangan } = data;
  const existing = getSheetData(SHEETS.ABSENSI).find(a => a.pertemuan_id === prtId && a.mahasiswa_id === mahasiswaId);
  if (existing) {
    updateRow(SHEETS.ABSENSI, "id", existing.id, { status, keterangan: keterangan || "" });
  } else {
    appendRow(SHEETS.ABSENSI, [uid(), prtId, mahasiswaId, status, keterangan || "", now()]);
  }
  return jsonRes({ ok: true });
}

