// ════════════════════════════════════════════════════════════════
// ENTRY POINT
// ════════════════════════════════════════════════════════════════
function doGet() {
  initSheets();
  return HtmlService.createHtmlOutputFromFile("index")
    .setTitle("EduCampus · " + CONFIG.NAMA_MATKUL)
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function doPost(e) {
  const data = JSON.parse(e.postData.contents);
  const action = data.action;
  try {
    const handlers = {
      login: handleLogin,
      register: handleRegister,
      getConfig: handleGetConfig,
      getPertemuan: handleGetPertemuan,
      getMateri: handleGetMateri,
      addMateri: handleAddMateri,
      deleteMateri: handleDeleteMateri,
      editTopik: handleEditTopik,
      getTugas: handleGetTugas,
      addTugas: handleAddTugas,
      deleteTugas: handleDeleteTugas,
      submitTugas: handleSubmitTugas,
      getSubmisiTugas: handleGetSubmisiTugas,
      nilaiTugas: handleNilaiTugas,
      getKuis: handleGetKuis,
      addKuis: handleAddKuis,
      deleteKuis: handleDeleteKuis,
      getSoal: handleGetSoal,
      addSoal: handleAddSoal,
      deleteSoal: handleDeleteSoal,
      submitKuis: handleSubmitKuis,
      getHasilKuis: handleGetHasilKuis,
      nilaiEssay: handleNilaiEssay,
      getAbsensi: handleGetAbsensi,
      submitAbsensi: handleSubmitAbsensi,
      updateAbsensi: handleUpdateAbsensi,
      getNotifikasi: handleGetNotifikasi,
      addNotifikasi: handleAddNotifikasi,
      deleteNotifikasi: handleDeleteNotifikasi,
      getNilaiMhs: handleGetNilaiMhs,
      updateNilai: handleUpdateNilai,
      getAllMahasiswa: handleGetAllMahasiswa,
      deleteMahasiswa: handleDeleteMahasiswa,
      updateProfile: handleUpdateProfile,
      getDashboard: handleGetDashboard,
    };
    if (!handlers[action]) return jsonRes({ ok: false, msg: "Action tidak dikenal" });
    return handlers[action](data);
  } catch (err) {
    return jsonRes({ ok: false, msg: err.toString() });
  }
}

// ════════════════════════════════════════════════════════════════
// INIT SHEETS
// ════════════════════════════════════════════════════════════════
function initSheets() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const headers = {
    [SHEETS.MAHASISWA]:    ["id","nama","email","password","nim","semester","prodi","created_at"],
    [SHEETS.PERTEMUAN]:    ["id","pertemuan_ke","topik","tanggal","keterangan"],
    [SHEETS.MATERI]:       ["id","pertemuan_id","judul","deskripsi","tipe","konten","file_url","created_at"],
    [SHEETS.TUGAS]:        ["id","pertemuan_id","judul","deskripsi","deadline","poin","file_url","created_at"],
    [SHEETS.TUGAS_SUBMIT]: ["id","tugas_id","mahasiswa_id","file_url","catatan","submitted_at","nilai","feedback"],
    [SHEETS.KUIS]:         ["id","pertemuan_id","judul","deskripsi","durasi_menit","created_at"],
    [SHEETS.KUIS_SOAL]:    ["id","kuis_id","urutan","tipe","pertanyaan","pilihan_a","pilihan_b","pilihan_c","pilihan_d","jawaban_benar","bobot"],
    [SHEETS.KUIS_JAWABAN]: ["id","kuis_id","mahasiswa_id","jawaban_json","nilai","status","submitted_at"],
    [SHEETS.ABSENSI]:      ["id","pertemuan_id","mahasiswa_id","status","keterangan","waktu"],
    [SHEETS.NOTIFIKASI]:   ["id","judul","isi","penting","created_at"],
    [SHEETS.NILAI]:        ["mahasiswa_id","uts","uas","tugas_rata","kuis_rata","nilai_akhir","huruf","updated_at"],
  };
  for (const [name, hdrs] of Object.entries(headers)) {
    let sh = ss.getSheetByName(name);
    if (!sh) {
      sh = ss.insertSheet(name);
      sh.getRange(1, 1, 1, hdrs.length).setValues([hdrs]).setFontWeight("bold").setBackground("#E8EAF6");
      sh.setFrozenRows(1);
    }
  }
  // Init 16 pertemuan jika kosong
  const prtSh = ss.getSheetByName(SHEETS.PERTEMUAN);
  if (prtSh.getLastRow() <= 1) {
    for (let i = 1; i <= 16; i++) {
      prtSh.appendRow([uid(), i, "", "", ""]);
    }
  }
}

// ════════════════════════════════════════════════════════════════
// AUTH
// ════════════════════════════════════════════════════════════════
function handleLogin(data) {
  const { email, password } = data;
  // Cek dosen
  if (email === CONFIG.DOSEN_EMAIL && password === CONFIG.DOSEN_PASSWORD) {
    return jsonRes({ ok: true, user: { id: "dosen", nama: CONFIG.DOSEN_NAMA, email, role: "dosen" } });
  }
  // Cek mahasiswa
  const rows = getSheetData(SHEETS.MAHASISWA);
  const mhs = rows.find(r => r.email === email && r.password === password);
  if (!mhs) return jsonRes({ ok: false, msg: "Email atau password salah" });
  return jsonRes({ ok: true, user: { id: mhs.id, nama: mhs.nama, email: mhs.email, nim: mhs.nim, semester: mhs.semester, prodi: mhs.prodi, role: "mahasiswa" } });
}

function handleRegister(data) {
  const { nama, email, password, nim, semester, prodi } = data;
  if (!nama || !email || !password || !nim) return jsonRes({ ok: false, msg: "Semua field wajib diisi" });
  const rows = getSheetData(SHEETS.MAHASISWA);
  if (rows.find(r => r.email === email)) return jsonRes({ ok: false, msg: "Email sudah terdaftar" });
  if (rows.find(r => r.nim === nim)) return jsonRes({ ok: false, msg: "NIM sudah terdaftar" });
  const id = uid();
  appendRow(SHEETS.MAHASISWA, [id, nama, email, password, nim, semester || 1, prodi || "", now()]);
  // Inisialisasi nilai kosong
  appendRow(SHEETS.NILAI, [id, "", "", "", "", "", "", now()]);
  return jsonRes({ ok: true, user: { id, nama, email, nim, semester, prodi, role: "mahasiswa" } });
}

// ════════════════════════════════════════════════════════════════
// CONFIG & DASHBOARD
// ════════════════════════════════════════════════════════════════
function handleGetConfig() {
  return jsonRes({ ok: true, config: CONFIG });
}

function handleGetDashboard(data) {
  const { userId, role } = data;
  const prts = getSheetData(SHEETS.PERTEMUAN);
  const totalPrt = prts.filter(p => p.topik).length;
  if (role === "dosen") {
    const mhs = getSheetData(SHEETS.MAHASISWA);
    const notifs = getSheetData(SHEETS.NOTIFIKASI).slice(-5).reverse();
    const tugasList = getSheetData(SHEETS.TUGAS);
    const submitList = getSheetData(SHEETS.TUGAS_SUBMIT);
    const tugasStats = tugasList.map(t => ({
      judul: t.judul,
      total_submit: submitList.filter(s => s.tugas_id === t.id).length,
      belum_nilai: submitList.filter(s => s.tugas_id === t.id && (s.nilai === "" || s.nilai === null)).length,
    })).slice(-5);
    return jsonRes({ ok: true, dashboard: { total_mhs: mhs.length, total_prt: totalPrt, notifs, tugas_stats: tugasStats } });
  } else {
    const absensiList = getSheetData(SHEETS.ABSENSI).filter(a => a.mahasiswa_id === userId);
    const hadir = absensiList.filter(a => a.status === "hadir").length;
    const tugasList = getSheetData(SHEETS.TUGAS);
    const submits = getSheetData(SHEETS.TUGAS_SUBMIT).filter(s => s.mahasiswa_id === userId);
    const notifs = getSheetData(SHEETS.NOTIFIKASI).slice(-5).reverse();
    const nilai = getSheetData(SHEETS.NILAI).find(n => n.mahasiswa_id === userId);
    return jsonRes({ ok: true, dashboard: {
      total_prt: totalPrt, hadir, total_absensi: absensiList.length,
      tugas_dikumpul: submits.length, total_tugas: tugasList.length,
      notifs, nilai: nilai || {}
    }});
  }
}

